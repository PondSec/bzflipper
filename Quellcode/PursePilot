#!/bin/bash

# PursePilot Launcher Script
# This script helps users run the PursePilot application

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Check if the binary exists
if [ -f "target/release/purse_pilot" ]; then
    echo "Running purse_pilot..."
    exec ./target/release/purse_pilot "$@"
elif [ -f "purse_pilot" ]; then
    echo "Running purse_pilot..."
    exec ./purse_pilot "$@"
else
    echo "Binary not found. Building from source..."
    if ! command -v cargo &> /dev/null; then
        echo "Error: cargo is not installed. Please install Rust from https://rustup.rs/"
        exit 1
    fi
    
    echo "Building release binary..."
    cargo build --release
    
    echo "Build complete. Running purse_pilot..."
    exec ./target/release/purse_pilot "$@"
fi
